# Copy to `.env` and edit.  cp .env.example .env

# ---- Ports (host side) ----
LLM_PORT=8010                # llama.cpp OpenAI API (/v1)
OPEN_WEBUI_PORT=3000         # Open WebUI
COMFYUI_PORT=8188            # ComfyUI (only with --profile comfyui)

# ---- Model selection (must be downloaded into ./volume/models) ----
# MODEL_HUB  = HF hub cache dir name (models--<org>--<repo>)
# MODEL_GLOB = filename glob to pick the quant
MODEL_HUB=models--unsloth--Qwen3.6-27B-MTP-GGUF
MODEL_GLOB=*Q4_K_XL.gguf

# ---- Inference ----
LLM_CTX=32768                # context length
LLM_CACHE_TYPE=f16           # KV 캐시 타입. f16=무손실·최고속도(권장) / q8_0=메모리 절반(속도↓·일부 환경 불안정) / q4_0=더 작게
LLM_GPUS=all                 # 사용할 GPU. all=전체 / "0"=GPU0만 / "0,1"=특정. 단일 모델이 한 장에 들어가면 "0"이 더 빠름
LLM_TENSOR_SPLIT=1,1         # GPU split. LLM_GPUS와 개수 맞출 것: 2장="1,1", 1장="1", 4장="1,1,1,1"
LLM_API_KEY=sk-local         # shared between llama-server (--api-key) and Open WebUI

# ---- Secrets / auth ----
# Strong random string. Keeps Open WebUI login sessions valid across restarts.
#   PowerShell: -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 48 | %{[char]$_})
WEBUI_SECRET_KEY=change-this-to-a-strong-secret

# Hugging Face token — needed to DOWNLOAD gated models (e.g. gemma-4). Qwen is open.
HF_TOKEN=
